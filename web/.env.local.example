# ---------------------------------------------------------------------------
# Frontend environment variables
# Copy this file to ".env.local" and fill in the values.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser (that is expected
# for the Supabase URL + anon key — they are safe to ship publicly).
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the custom REST backend
NEXT_PUBLIC_API_URL=http://localhost:4000

# WebSocket endpoint of the custom realtime backend.
# Note the "/doc" suffix — the document id is appended as the room name.
NEXT_PUBLIC_WS_URL=ws://localhost:4000/doc
