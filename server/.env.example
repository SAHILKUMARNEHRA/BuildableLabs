# ---------------------------------------------------------------------------
# Backend environment variables
# Copy this file to ".env" and fill in the values from your Supabase project.
# (Supabase Dashboard -> Project Settings -> API)
# ---------------------------------------------------------------------------

# Port the HTTP + WebSocket server listens on
PORT=4000

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Service role key (server-side only, NEVER expose this to the browser).
# Used to verify user tokens and to persist documents past row-level security.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket that holds the binary Yjs document snapshots.
# Create it in Supabase Dashboard -> Storage (see SETUP.md).
SUPABASE_STORAGE_BUCKET=documents

# Comma-separated list of origins allowed to call the REST API / open sockets.
# In development this is the Next.js dev server.
CORS_ORIGINS=http://localhost:3000
